# Minbot 的监听端口和地址
HOST=127.0.0.1
PORT=12000

# 开启高级输出
ENABLE_ADVANCE_OUTPUT=false

# 插件配置
PLUGINS=["src.plugins.chat"]

# 默认配置
DATABASE_PATH=data/minbot.db

# 模型的 url 和 key
# ChatAntWhere
CHAT_ANY_WHERE_BASE_URL=https://api.chatanywhere.tech/v1
CHAT_ANY_WHERE_KEY=

# 硅基流动
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1/
SILICONFLOW_KEY=

# Deepseek 官方
DEEP_SEEK_BASE_URL=https://api.deepseek.com/v1
DEEP_SEEK_KEY=

# 自定义模型1
EXAMPLE_1_BASE_URL=http://127.0.0.1:5000/v1
EXAMPLE_1_KEY=

# 自定义模型2
EXAMPLE_2_BASE_URL=http://127.0.0.1:5001/v1
EXAMPLE_2_KEY=

# 定义日志相关配置
CONSOLE_LOG_LEVEL=INFO   # 自定义日志的默认控制台输出日志级别
FILE_LOG_LEVEL=INFO  # 自定义日志的默认文件输出日志级别
DEFAULT_CONSOLE_LOG_LEVEL=SUCCESS   # 原生日志的控制台输出日志级别（nonebot）
DEFAULT_FILE_LOG_LEVEL=INFO   # 原生日志的默认文件输出日志级别（nonebot）

# API 调用相关配置
SINGLE_API_MODE=true   # 是否启用单次API调用模式（true: 单次调用, false: 多次调用）
API_RETRY_BASE_WAIT_TIME=15   # API请求失败时的基础等待时间（秒）

# 表情包配置
EMOJI_ENABLED=true # 是否启用表情包抓取与保存（true/false）
EMOJI_MAX_COUNT=200 # 表情包库最大数量上限，超过上限时自动删除最旧的表情包再存入新的（0=不限制）
EMOJI_SEND_ENABLED=true # 是否允许发送表情包（true/false）

# WebUI 账户密码和安全密钥，留空则启动时自动生成随机密钥
WEBUI_USERNAME=
WEBUI_PASSWORD=
SECRET_KEY=    

# 启动 BOT 的命令（可选）。如果设置了该值，WebUI 将在启动 BOT 子进程时解析并使用该值作为前缀。如果留空/未设置，WebUI 将使用运行 WebUI 进程的相同 Python 解释器。
# 示例：BOT_START_CMD=uv run
BOT_START_CMD=